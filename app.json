{
  "expo": {
    "name": "squiz",
    "slug": "squiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#17022d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saurav.squiz"
    },
    "android": {
      "package": "com.saurav.squiz",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#17022d"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-router",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "47a8f079-276a-4544-85cb-ab125f1c9ade"
      }
    }
  }
}
