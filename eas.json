{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SOLANA_NETWORK": "devnet"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SOLANA_NETWORK": "mainnet-beta",
        "EXPO_PUBLIC_TREASURY_URL": "https://seekerrank-production.up.railway.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_SOLANA_NETWORK": "mainnet-beta"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
